  "wordnet_nouns": [
    "pip install --quiet --no-cache-dir nltk",
    "python -c \"import nltk; nltk.download('wordnet', quiet=True)\"",
    "DB_COMMAND_TIMEOUT=300 python -m world_of_taxonomy ingest wordnet_nouns"
  ],

  "geonames_features": [
    "mkdir -p data",
    "curl -fsSL https://download.geonames.org/export/dump/featureCodes_en.txt -o data/geonames_featureCodes_en.txt",
    "python -m world_of_taxonomy ingest geonames_features"
  ],

  "gs1_gpc": [
    "mkdir -p data",
    "test -f \"data/GPC as of November 2025 v20251127 GB.xlsx\" || (echo 'ERROR: GS1 GPC requires manual download from https://gpc-browser.gs1.org/ (registration required); upload to repo data/ before running this task' >&2 && exit 2)",
    "python -m world_of_taxonomy ingest gs1_gpc"
  ]
